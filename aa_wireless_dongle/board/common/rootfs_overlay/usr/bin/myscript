#!/usr/bin/env python

import os
import time
import signal
import sys
import RPi.GPIO as GPIO
import subprocess
import re
import pathlib
import filecmp

switch1 = ''
switch2 = ''
switch3 = ''
switch4 = ''
mode = ''
#bounce = 50
#demonio = "/etc/init.d/s93aa-proxy-rs"
demonio = "/etc/init.d/s93aawgd"
start = [0.0 , 0.0 , 0.0 , 0.0]
end = [0.0 , 0.0 , 0.0 , 0.0]
flags = [0,0,0,0]
press = 1

def check_string (f,s):
    f1 = open(f,'r')
    d = f1.readlines()
    f1.close()
    for line in d:
        if s in line:
            return True
    return False

def set_mode (m):
    global mode
    if not os.path.exists('/persist/mode'):
        pathlib.Path('/persist/mode').touch()
    f = open("/persist/mode", "w")
    f.write(m)
    f.close()
    mode = m

def get_mode ():
    global mode
    if os.path.exists('/persist/mode'):
        f = open("/persist/mode", "r")
        o = f.readline().replace("\n","")
        f.close()
        return o
    else:
        return '0'

def get_device ():
    f = open("/proc/device-tree/model", "r")
    o = f.readline().replace("\n","").rstrip()
    f.close()
    match o:
        case str(x) if 'Raspberry Pi 3 Model A Plus Rev 1.0' in x:
            return 'rpi3a'
        case str(x) if 'Raspberry Pi 4 Model B Rev 1.1' in x:
            return 'rpi4'
        case str(x) if  'Raspberry Pi Zero W Rev 1.1' in x:
            return 'rpi0w'
        case str(x) if  'Raspberry Pi Zero 2 W Rev 1.0' in x:
            return 'rpi0w'

def setup_switchs (dev):
    global switch1
    global switch2
    global switch3
    global switch4
    global bounce
    GPIO.setmode(GPIO.BCM)
    match dev:
      case 'rpi4':
          switch1 = 0
          switch2 = 0
          switch3 = 0
          switch4 = 0
      case 'rpi3a':
          switch1 = 8
          switch2 = 25
          switch3 = 24
          switch4 = 23
      case 'rpi0w':
          switch1 = 15
          switch2 = 24
          switch3 = 7
          switch4 = 20
    if switch1 > 0:
        GPIO.setup(switch1,GPIO.IN,pull_up_down=GPIO.PUD_UP)
        #GPIO.add_event_detect(switch1,GPIO.BOTH,buttonEventHandler,bounce)
        GPIO.add_event_detect(switch1,GPIO.BOTH,buttonEventHandler)
    if switch2 > 0:
        GPIO.setup(switch2,GPIO.IN,pull_up_down=GPIO.PUD_UP)
        #GPIO.add_event_detect(switch2,GPIO.BOTH,buttonEventHandler,bounce)
        GPIO.add_event_detect(switch2,GPIO.BOTH,buttonEventHandler)
    if switch3 > 0:
        GPIO.setup(switch3,GPIO.IN,pull_up_down=GPIO.PUD_UP)
        #GPIO.add_event_detect(switch3,GPIO.BOTH,buttonEventHandler,bounce)
        GPIO.add_event_detect(switch3,GPIO.BOTH,buttonEventHandler)
    if switch4 > 0:
        GPIO.setup(switch4,GPIO.IN,pull_up_down=GPIO.PUD_UP)
        #GPIO.add_event_detect(switch4,GPIO.BOTH,buttonEventHandler,bounce)
        GPIO.add_event_detect(switch4,GPIO.BOTH,buttonEventHandler)

def change_demonio ():
    subprocess.run(f"sed -i 's/demonio = /#demonio = /' myscript", shell=True)
    subprocess.run(f"sed -i 's/##demonio = /demonio = /' myscript", shell=True)

def change_wifi ():
    if filecmp.cmp ( '/etc/hostapd.conf' , '/etc/hostapd.conf2') :
        subprocess.run(['/bin/cp','-f','/etc/hostapd.conf5','/etc/hostapd.conf'])
    else:
        subprocess.run(['/bin/cp','-f','/etc/hostapd.conf2','/etc/hostapd.conf'])

def mode_idle ():
    global demonio
    subprocess.run(["modprobe","-r", "g_mass_storage"])
    subprocess.run(["/etc/init.d/s91smb","stop"])
    subprocess.run([demonio,"stop"])
    subprocess.run(["/etc/init.d/s92usb_gadget","stop"])

def mode_androidauto ():
    global mode
    global demonio
    set_mode('1')
    mode_idle()
    subprocess.run(["/etc/init.d/s92usb_gadget","restart"])
    subprocess.run([demonio,"restart"])

def mode_debug ():
    global mode
    set_mode('2')
    mode_idle()
    subprocess.run(["/etc/init.d/s91smb","restart"])
    subprocess.run(["/etc/init.d/s50dropbear","restart"])
    subprocess.run(["mount","-o","remount,rw","/"])
    subprocess.run(["mount","-o","remount,rw","/boot"])

def mode_usb0 ():
    global mode
    set_mode('7')
    mode_idle()

def mode_usb1 ():
    global mode
    set_mode('3')
    mode_idle()
    subprocess.run(["modprobe","g_mass_storage", "file=/mnt/storage/usb1.img" , "stall=0" ,"ro=0", "removable=1"])

def mode_usb2 ():
    global mode
    set_mode('4')
    mode_idle()
    subprocess.run(["modprobe","g_mass_storage", "file=/mnt/storage/usb2.img" , "stall=0" ,"ro=0", "removable=1"])

def mode_usb3 ():
    global mode
    set_mode('5')
    mode_idle()
    subprocess.run(["modprobe","g_mass_storage", "file=/mnt/storage/usb3.img" , "stall=0" ,"ro=0", "removable=1"])

def mode_usb4 ():
    global mode
    set_mode('6')
    mode_idle()
    subprocess.run(["modprobe","g_mass_storage", "file=/mnt/storage/usb4.img" , "stall=0" ,"ro=0", "removable=1"])

def buttonEventHandler (pin):
     global start
     global end
     global flags
     if pin == switch1: i = 0
     if pin == switch2: i = 1
     if pin == switch3: i = 2
     if pin == switch4: i = 3
     if GPIO.input(pin):
         end[i]=time.time()
         if (end[i]-start[i]) > press:
             if sum(flags) == 2 :
                 if flags[0] == 1 and flags[1] ==1: twolongpress(1,2)
                 if flags[0] == 1 and flags[2] ==1: twolongpress(1,3)
                 if flags[0] == 1 and flags[3] ==1: twolongpress(1,4)
                 if flags[1] == 1 and flags[2] ==1: twolongpress(2,3)
                 if flags[1] == 1 and flags[3] ==1: twolongpress(2,4)
                 if flags[2] == 1 and flags[3] ==1: twolongpress(3,4)
                 flags = [0,0,0,0]
             if sum(flags) == 1 :
                 flags[i]=0
                 longpress(i+1)
         else:
             if sum(flags) == 2 :
                 if flags[0] == 1 and flags[1] ==1 : twoshortpress(1,2)
                 if flags[0] == 1 and flags[2] ==1 : twoshortpress(1,3)
                 if flags[0] == 1 and flags[3] ==1 : twoshortpress(1,4)
                 if flags[1] == 1 and flags[2] ==1 : twoshortpress(2,3)
                 if flags[1] == 1 and flags[3] ==1 : twoshortpress(2,4)
                 if flags[2] == 1 and flags[3] ==1 : twoshortpress(3,4)
                 flags = [0,0,0,0]
             if sum(flags) == 1 :
                 flags[i]=0
                 shortpress(i+1)
     else:
         flags[i]=1
         start[i]=time.time()

def longpress (i):
    global mode
    if i == 1 and mode == '1':
        force_reconnect()
    if i == 2 and mode != '5':
        mode_usb3()
    if i == 3 and mode != '6':
        mode_usb4()
    if i == 4 and mode != '2':
        mode_debug()

def shortpress (i):
    global mode
    if mode == '2' and i == 1:
        set_mode('1')
        clean()
        subprocess.run('reboot')
        sys.exit(0)
    if mode == '2' and i == 2:
        set_mode('1')
        clean()
        change_wifi()
        subprocess.run('reboot')
        sys.exit(0)
    if mode == '2' and i == 3:
        set_mode('1')
        clean()
        change_demonio()
        subprocess.run('reboot')
        sys.exit(0)
    if i == 1 and mode != '1' :
        mode_androidauto()
    if i == 2 and mode != '3':
        mode_usb1()
    if i == 3 and mode != '4':
        mode_usb2()
    if i == 4 and mode != '7':
        mode_usb0()

def twolongpress (i,j):
    print('long press: '+str(i)+" : "+str(j))

def twoshortpress (i,j):
    print('short press: '+str(i)+" : "+str(j))

def force_reconnect ():
    global demonio
    subprocess.run([demonio,"stop"])
    time.sleep(1)
    subprocess.run(["/etc/init.d/s92usb_gadget","restart"])
    time.sleep(1)
    subprocess.run([demonio,"start"])

def clean ():
    GPIO.cleanup()

def signal_handler(sig, frame):
    clean()
    sys.exit(0)

def signal_handler2(sig, frame):
    force_reconnect()

# main function
def main():
    global mode
    mode = get_mode()
    setup_switchs(get_device())
    signal.signal(signal.SIGUSR1, signal_handler2)
    signal.signal(signal.SIGHUP, signal_handler)
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGQUIT, signal_handler)
    signal.signal(signal.SIGABRT, signal_handler)
    signal.signal(signal.SIGALRM, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)

    match mode:
        case '0':
            mode_androidauto()
        case '1':
            mode_androidauto()
        case '2':
            mode_debug()
        case '3':
            mode_usb1()
        case '4':
            mode_usb2()
        case '5':
            mode_usb3()
        case '6':
            mode_usb4()
        case '7':
            mode_usb0()

    while True:
        time.sleep(1)

    #signal.pause()
    GPIO.cleanup()

if __name__=="__main__":
    main()
