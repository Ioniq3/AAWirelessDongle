        if [ $(cat /etc/fstab | grep usb2 | wc -l | tr -d '\\n') -eq 0 ]
        then 
                mkdir /mnt/usb2
                sh -c 'echo "/root/usb2.img /mnt/usb2 vfat rw,users,umask=000,nofail 0 2" >> /etc/fstab'
