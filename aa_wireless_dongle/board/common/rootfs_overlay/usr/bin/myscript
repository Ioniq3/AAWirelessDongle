#!/usr/bin/env python

import os
import time
import signal
import sys
import RPi.GPIO as GPIO
import logging
from logging.handlers import RotatingFileHandler
import subprocess
import re
import pathlib

switch1 = ''
switch2 = ''
switch3 = ''
switch4 = ''
mode = ''
start = [0.0 , 0.0 , 0.0 , 0.0]
end = [0.0 , 0.0 , 0.0 , 0.0]
flags = [0,0,0,0]
press = 2.0
pro = ''
pulsaciones = 0

file_pre = '''#!/bin/sh
if [ ! -e /dev/mmcblk0p3 ]
then
echo "n
p
3
61184000
t
3
83
w
" |  fdisk /dev/mmcblk0
        sh -c 'echo "/dev/mmcblk0p3 /root ext4 defaults,nofail 0 0" >> /etc/fstab'
        sed -i 's/country_code=IN/country_code=ES/' /etc/hostapd.conf
        reboot
        exit 0
fi
if [ $(cat /etc/fstab | grep mmcblk0p3 | wc -l | tr -d '\\n') -eq 0 ]
then 
        sh -c 'echo "/dev/mmcblk0p3 /root ext4 defaults,nofail 0 0" >> /etc/fstab'
        mount -a
fi
if [ ! -f /etc/samba/smb.conf ]
then
cat <<EOF | tee /etc/samba/smb.conf
[global]
        log file = /var/log/samba/%m
        log level = 1
        server role = standalone server
[usb1]
        # This share requires authentication to access
        path = /mnt/usb1
        force user = root
