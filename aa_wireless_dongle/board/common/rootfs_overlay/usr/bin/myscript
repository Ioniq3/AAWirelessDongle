        if [ $(cat /etc/fstab | grep usb3 | wc -l | tr -d '\\n') -eq 0 ]
        then
                mkdir /mnt/usb3
                sh -c 'echo "/root/usb3.img /mnt/usb3 vfat rw,users,umask=000,nofail 0 2" >> /etc/fstab'
                mount -a
        fi
rm /root/config/mode
fi
'''

def charge_files ():
    f = open('/tmp/pre','w')
    f.write(file_pre)
    f.close()
    os.system('chmod +x /tmp/pre')

def check_string (f,s):
    f1 = open(f,'r')
    d = f1.readlines()
    f1.close()
    for line in d:
        if s in line:
            return True
    return False

def preinstallation ():
    subprocess.run('/tmp/pre')

def set_mode (m):
    global mode
    if not os.path.exists('/root/config/mode'):
        pathlib.Path('/root/config/mode').touch()
    f = open("/root/config/mode", "w")
    f.write(m)
    f.close()
    logging.info('Cambio a modo '+m)
    mode = m

def get_mode ():
    global mode
    if os.path.exists('/root/config/mode'):
        f = open("/root/config/mode", "r")
        o = f.readline().replace("\n","")
        f.close()
        return o
    else:
        return '0'

def get_device ():
    f = open("/proc/device-tree/model", "r")
    o = f.readline().replace("\n","").rstrip()
    f.close()
    match o:
        case str(x) if 'Raspberry Pi 3 Model A Plus Rev 1.0' in x:
            return 'rpi3a'
        case str(x) if 'Raspberry Pi 4 Model B Rev 1.1' in x:
            return 'rpi4'
        case str(x) if  'Raspberry Pi Zero W Rev 1.1' in x:
            return 'rpi0w'

def setup_switchs (dev):
    global switch1
    global switch2
    global switch3
    global switch4
    GPIO.setmode(GPIO.BCM)
    match dev:
      case 'rpi4':
          switch1 = 0
          switch2 = 0
          switch3 = 0
          switch4 = 0
      case 'rpi3a':
          switch1 = 8
          switch2 = 25
          switch3 = 24
          switch4 = 23
      case 'rpi0w':
          switch1 = 15
          switch2 = 24
          switch3 = 7
          switch4 = 20
    if switch1 > 0:
        GPIO.setup(switch1,GPIO.IN,pull_up_down=GPIO.PUD_UP)
        GPIO.add_event_detect(switch1,GPIO.BOTH,buttonEventHandler,100)
    if switch2 > 0:
        GPIO.setup(switch2,GPIO.IN,pull_up_down=GPIO.PUD_UP)
        GPIO.add_event_detect(switch2,GPIO.BOTH,buttonEventHandler,100)
    if switch3 > 0:
        GPIO.setup(switch3,GPIO.IN,pull_up_down=GPIO.PUD_UP)
        GPIO.add_event_detect(switch3,GPIO.BOTH,buttonEventHandler,100)
    if switch4 > 0:
        GPIO.setup(switch4,GPIO.IN,pull_up_down=GPIO.PUD_UP)
        GPIO.add_event_detect(switch4,GPIO.BOTH,buttonEventHandler,100)

def mode_androidauto ():
    global mode
    logging.info('enter into mode_androidauto')
    set_mode('1')
    subprocess.run(["modprobe","-r", "g_mass_storage"])
    subprocess.run(["/etc/init.d/S92usb_gadget","restart"])
    subprocess.run(["/etc/init.d/S93aawgd","restart"])

def mode_debug ():
    global mode
    logging.info('enter into mode_idle')
    set_mode('2')
    subprocess.run(["modprobe","-r", "g_mass_storage"])
    subprocess.run(["/etc/init.d/S93aawgd","stop"])
    subprocess.run(["/etc/init.d/S92usb_gadget","stop"])
    #subprocess.run(["modprobe","g_mass_storage", "file=/root/usb0.img" , "stall=0" ,"ro=0", "removable>

def mode_usb1 ():
    global mode
    logging.info('enter into mode_usb1')
    set_mode('3')
    subprocess.run(["modprobe","-r", "g_mass_storage"])
    subprocess.run(["/etc/init.d/S93aawgd","stop"])
    subprocess.run(["/etc/init.d/S92usb_gadget","stop"])
    subprocess.run(["modprobe","g_mass_storage", "file=/root/usb1.img" , "stall=0" ,"ro=0", "removable=>

def mode_usb2 ():
    global mode
    logging.info('enter into mode_usb2')
    set_mode('4')
    subprocess.run(["modprobe","-r", "g_mass_storage"])
    subprocess.run(["/etc/init.d/S93aawgd","stop"])
    subprocess.run(["/etc/init.d/S92usb_gadget","stop"])
    subprocess.run(["modprobe","g_mass_storage", "file=/root/usb2.img" , "stall=0" ,"ro=0", "removable=>

def mode_usb3 ():
    global mode
    logging.info('enter into mode_usb3')
    set_mode('5')
    subprocess.run(["modprobe","-r", "g_mass_storage"])
    subprocess.run(["/etc/init.d/S93aawgd","stop"])
    subprocess.run(["/etc/init.d/S92usb_gadget","stop"])
    subprocess.run(["modprobe","g_mass_storage", "file=/root/usb3.img" , "stall=0" ,"ro=0", "removable=>

def buttonEventHandler (pin):
     global start
     global end
     global pulsaciones
     global flags
     if pin == switch1: i = 0
     if pin == switch2: i = 1
     if pin == switch3: i = 2
     if pin == switch4: i = 3
     if GPIO.input(pin):
         end[i]=time.time()
         if (end[i]-start[i]) > press:
             if sum(flags) == 2 :
                 if flags[0] == 1 and flags[1] ==1: twolongpress(1,2)
                 if flags[0] == 1 and flags[2] ==1: twolongpress(1,3)
                 if flags[0] == 1 and flags[3] ==1: twolongpress(1,4)
                 if flags[1] == 1 and flags[2] ==1: twolongpress(2,3)
                 if flags[1] == 1 and flags[3] ==1: twolongpress(2,4)
                 if flags[2] == 1 and flags[3] ==1: twolongpress(3,4)
                 flags = [0,0,0,0]
             if sum(flags) == 1 :
                 flags[i]=0
                 longpress(i+1)
         else:
             if sum(flags) == 2 :
                 if flags[0] == 1 and flags[1] ==1 : twoshortpress(1,2)
                 if flags[0] == 1 and flags[2] ==1 : twoshortpress(1,3)
                 if flags[0] == 1 and flags[3] ==1 : twoshortpress(1,4)
                 if flags[1] == 1 and flags[2] ==1 : twoshortpress(2,3)
                 if flags[1] == 1 and flags[3] ==1 : twoshortpress(2,4)
                 if flags[2] == 1 and flags[3] ==1 : twoshortpress(3,4)
                 flags = [0,0,0,0]
             if sum(flags) == 1 :
                 flags[i]=0
                 shortpress(i+1)
     else:
         flags[i]=1
         start[i]=time.time()

def longpress (i):
    global mode
    logging.info('long press: '+str(i))
    if i == 1 and mode == '1':
        force_reconnect()
    if i == 2 and mode != '2':
        mode_debug()
    if i == 3:
        clean()
        subprocess.run('reboot')
        sys.exit(0)
    if i == 4:
        clean()
        subprocess.run('poweroff')
        sys.exit(0)    
    logging.info('boton mode '+mode)

def shortpress (i):
    global mode
    logging.info('short press: '+str(i))
    if i == 1 and mode != '1' :
        mode_androidauto()
    if i == 2 and mode != '3':
        mode_usb1()
    if i == 3 and mode != '4':
        mode_usb2()
    if i == 4 and mode != '5':
        mode_usb3()
    logging.info('boton mode '+mode)

def twolongpress (i,j):
    logging.info('long press: '+str(i)+" : "+str(j))

def twoshortpress (i,j):
    logging.info('short press: '+str(i)+" : "+str(j))

def clean ():
    GPIO.cleanup()
    logging.shutdown()

def signal_handler(sig, frame):
    clean()
    sys.exit(0)

def signal_handler2(sig, frame):
    subprocess.run(["/etc/init.d/S93aawgd","stop"])
    time.sleep(1)
    subprocess.run(["/etc/init.d/S92usb_gadget","restart"])
    time.sleep(1)
    subprocess.run(["/etc/init.d/S93aawgd","start"])

def execute_command ():
    print()

def force_reconnect ():
    subprocess.run(["/etc/init.d/S92usb_gadget","restart"])
    subprocess.run(["/etc/init.d/S93aawgd","restart"])

# main function
def main():
    global mode
    charge_files()
    logging.basicConfig(filename='/tmp/log.txt', encoding='utf-8', level=logging.INFO)

    mode = get_mode()
    logging.info('Arranco en modo: ' + mode + ' con el dispositivo ' + str(get_device()) )
    setup_switchs(get_device())
    signal.signal(signal.SIGHUP, signal_handler)
    signal.signal(signal.SIGINT, signal_handler2)
    signal.signal(signal.SIGQUIT, signal_handler)
    signal.signal(signal.SIGABRT, signal_handler)
    signal.signal(signal.SIGALRM, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)

    match mode:
        case '0':
            preinstallation()
            m = ''
            while m == '':
                m = os.popen("bluetoothctl devices | awk '{print $2}' | tail -1 | tr -d '\n'").readline>
            set_mode('1')
        case '1':
            print()
        case '2':
            mode_debug()
        case '3':
            mode_usb1()
        case '4':
            mode_usb2()
        case '5':
            mode_usb3()

    while True:
        time.sleep(1)
        if switch1 == 0:
            if os.path.exists('/root/config/1'):
                os.remove('/root/config/1')
                shortpress(1)
        if switch2 == 0:
            if os.path.exists('/root/config/2'):
                os.remove('/root/config/2')
                shortpress(2)
        if switch3 == 0:
            if os.path.exists('/root/config/3'):
                os.remove('/root/config/3')
                shortpress(3)
        if switch4 == 0:
            if os.path.exists('/root/config/4'):
                os.remove('/root/config/4')
                shortpress(4)

    #signal.pause()
    GPIO.cleanup()

if __name__=="__main__":
    main()
